<%- include('../_header', { title: '수집 이력' }) %>

<h1>Raw 수집 이력</h1>

<% if (selectedServer) { %>
  <h3><%= selectedServer.name %> (<%= selectedServer.hostname %>) 의 수집 이력</h3>
  <a href="/collect/history" class="btn-sm">전체 이력 보기</a>
<% } %>

<table class="data-table">
  <thead>
    <tr>
      <th>시작</th><th>종료</th><th>서버</th><th>상태</th>
      <th>파일 경로 / 사유</th><th>크기</th><th>해시</th><th>실행자</th>
    </tr>
  </thead>
  <tbody>
    <% recent.forEach(c => { %>
      <tr class="status-<%= c.status==='성공'?'safe':c.status==='실패'?'vuln':'' %>">
        <td class="small"><%= c.started_at %></td>
        <td class="small"><%= c.finished_at || '-' %></td>
        <td>
          <% if (c.server_name) { %>
            <%= c.server_name %> <span class="muted small">(<%= c.hostname %>)</span>
          <% } else { %>
            <%= selectedServer ? selectedServer.name : `#${c.server_id}` %>
          <% } %>
        </td>
        <td><span class="badge b-<%= c.status==='성공'?'safe':c.status==='실패'?'vuln':'na' %>"><%= c.status %></span></td>
        <td class="small">
          <% if (c.status==='성공') { %>
            <code><%= c.raw_file_path %></code>
          <% } else if (c.error_message) { %>
            <span style="color:#c0392b"><%= c.error_message %></span>
          <% } %>
        </td>
        <td class="small"><%= c.file_size ? Math.round(c.file_size/1024)+' KB' : '-' %></td>
        <td class="small"><code><%= c.raw_file_hash ? c.raw_file_hash.slice(0,12)+'...' : '-' %></code></td>
        <td class="small"><%= c.triggered_by || '-' %></td>
      </tr>
    <% }); %>
    <% if (!recent.length) { %>
      <tr><td colspan="8" class="empty">수집 이력이 없습니다.</td></tr>
    <% } %>
  </tbody>
</table>

<a href="/collect" class="btn">수집 화면으로</a>

<%- include('../_footer') %>
