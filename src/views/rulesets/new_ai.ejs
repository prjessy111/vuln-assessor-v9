<%- include('../_header', { title: 'AI 룰 자동 제안', activeMenu: 'rulesets' }) %>

<div class="page-header">
  <h1>AI 자동 진단 항목 제안</h1>
  <div class="mode-tabs">
    <a href="?mode=form" class="tab">📝 폼 입력</a>
    <a href="?mode=yaml" class="tab">⌨️ YAML</a>
    <a href="?mode=ai" class="tab active">🤖 AI 제안</a>
  </div>
</div>

<div class="section-box">
  <h3>1단계: raw 데이터 분석 대상 선택</h3>
  <p class="muted small">AI가 분석할 raw 데이터를 선택하세요. 여러 서버의 데이터를 종합하면 더 정확한 제안을 받을 수 있습니다.</p>
  <div class="ai-target-grid">
    <label class="ai-target-card selected">
      <input type="checkbox" checked>
      <div class="atc-name">jessy62</div>
      <div class="atc-meta">CentOS 7.5 / 내부 결제 DB</div>
      <div class="atc-tables">33개 테이블 발견</div>
    </label>
    <label class="ai-target-card">
      <input type="checkbox">
      <div class="atc-name">linux-prod-02</div>
      <div class="atc-meta">RHEL 8.5 / 주문 API</div>
      <div class="atc-tables">31개 테이블 발견</div>
    </label>
    <label class="ai-target-card">
      <input type="checkbox">
      <div class="atc-name">linux-db-01</div>
      <div class="atc-meta">CentOS 7.9 / 결제 DB</div>
      <div class="atc-tables">33개 테이블 발견</div>
    </label>
  </div>
</div>

<div class="section-box">
  <h3>2단계: 분석 옵션</h3>
  <div class="form-grid">
    <div class="form-row">
      <label>관심 카테고리 (다중 선택)</label>
      <div class="check-group">
        <label class="check"><input type="checkbox" checked> 계정 및 권한관리</label>
        <label class="check"><input type="checkbox" checked> 서비스 보호</label>
        <label class="check"><input type="checkbox" checked> 파일 권한</label>
        <label class="check"><input type="checkbox"> 로그 관리</label>
        <label class="check"><input type="checkbox"> 네트워크</label>
      </div>
    </div>
    <div class="form-row">
      <label>제외할 기존 룰</label>
      <p class="muted small">현재 14개 룰을 자동으로 제외하고 신규 항목만 제안합니다.</p>
    </div>
    <div class="form-row">
      <label>참조 표준</label>
      <select multiple class="multi-select">
        <option selected>금융보안원 가이드 (FSI)</option>
        <option selected>주요정보통신기반시설 기술적 취약점 분석·평가 방법 상세가이드 (KISA)</option>
        <option>CIS Benchmarks</option>
        <option>STIG (미 국방부)</option>
      </select>
    </div>
  </div>
  <button class="btn primary">🤖 AI 분석 시작</button>
</div>

<div class="section-box">
  <h3>3단계: AI 제안 결과 <span class="muted small">(13개 항목 제안됨 — 7초 소요)</span></h3>
  <p class="muted small">각 제안을 검토하고 채택할 항목을 선택하세요. 채택한 룰은 즉시 룰셋에 추가됩니다.</p>
  
  <div class="ai-suggestions">
    <% suggestions.forEach((s, idx) => { %>
      <div class="ai-suggestion-card priority-<%= s.priority %>">
        <div class="ais-header">
          <label class="check-large">
            <input type="checkbox" <%= s.recommended ? 'checked' : '' %>>
            <span class="ais-id"><%= s.rule_id %></span>
            <span class="ais-title"><%= s.title %></span>
          </label>
          <div class="ais-meta">
            <span class="sev sev-<%= s.severity %>"><%= s.severity %></span>
            <span class="ais-category"><%= s.category %></span>
            <span class="ais-confidence">신뢰도 <%= s.confidence %>%</span>
          </div>
        </div>
        
        <div class="ais-body">
          <div class="ais-rationale">
            <strong>💡 제안 근거:</strong> <%= s.rationale %>
          </div>
          
          <div class="ais-grid">
            <div class="ais-col">
              <h5>관련 테이블 / Raw 단서</h5>
              <code class="ais-table-hint"><%= s.related_tables %></code>
              <div class="ais-data-sample">
                <%= s.data_sample %>
              </div>
            </div>
            <div class="ais-col">
              <h5>생성된 룰 (YAML)</h5>
              <pre class="yaml-mini"><code><%= s.yaml_preview %></code></pre>
            </div>
          </div>

          <% if (s.related_cves && s.related_cves.length) { %>
            <div class="ais-cves">
              <strong>관련 CVE:</strong>
              <% s.related_cves.forEach(c => { %>
                <span class="cve-tag cvss-<%= c.severity_class %>">
                  <%= c.id %> · CVSS <%= c.cvss %>
                </span>
              <% }); %>
            </div>
          <% } %>
        </div>
        
        <div class="ais-actions">
          <button class="btn-sm">미리보기 / 편집</button>
          <button class="btn-sm">테스트 실행</button>
          <button class="btn-sm danger">건너뛰기</button>
        </div>
      </div>
    <% }); %>
  </div>

  <div class="bulk-actions">
    <button class="btn primary">선택한 8개 항목 일괄 추가</button>
    <button class="btn">선택한 항목 YAML 다운로드</button>
    <a href="/rulesets" class="btn">취소</a>
  </div>
</div>

<%- include('../_footer') %>
