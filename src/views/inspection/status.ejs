<%- include('../_header', { title: '점검현황', activeMenu: 'inspection-status' }) %>
<style>
  .insp-summary { max-width:560px; }
  .insp-summary td.num { text-align:right; font-weight:700; }
  .insp-summary td.warn { color:#c0392b; }
  .grade-badge { display:inline-block; min-width:20px; padding:1px 7px; border-radius:10px; font-weight:800; font-size:12px; color:#fff; }
  .g-A{background:#1aa260;} .g-B{background:#2980b9;} .g-C{background:#f39c12;} .g-D{background:#e67e22;} .g-F{background:#c0392b;} .g--{background:#95a5a6;}
  .chk-yes{color:#1aa260;font-weight:700;} .chk-no{color:#c0392b;font-weight:700;}
  .ch-badge{display:inline-block;padding:2px 8px;border-radius:4px;background:#eaf5ea;color:#1e8449;font-size:11px;font-weight:700;}
</style>

<div class="page-header">
  <h1>점검현황</h1>
  <div class="header-actions">
    <span class="muted small">기준일: <%= now %></span>
  </div>
</div>

<!-- OS별 점검 집계 -->
<div class="section-box">
  <h3>OS별 점검 현황</h3>
  <table class="data-table insp-summary">
    <thead><tr><th>구분</th><th>전체</th><th>점검완료</th><th>미점검</th></tr></thead>
    <tbody>
      <% osSummary.forEach(o => { %>
        <tr>
          <td><strong><%= String(o.os).toUpperCase() %></strong></td>
          <td class="num"><%= o.total %></td>
          <td class="num"><%= o.total - o.unchecked %></td>
          <td class="num <%= o.unchecked ? 'warn' : '' %>"><%= o.unchecked %></td>
        </tr>
      <% }); %>
      <tr style="background:#f7f9fc;">
        <td><strong>합계</strong></td>
        <td class="num"><%= totalCount %></td>
        <td class="num"><%= checkedCount %></td>
        <td class="num <%= (totalCount-checkedCount) ? 'warn' : '' %>"><%= totalCount - checkedCount %></td>
      </tr>
    </tbody>
  </table>
  <% if (totalCount === checkedCount && totalCount > 0) { %>
    <p class="muted small">✓ 전체 서버 점검 완료</p>
  <% } else if (totalCount === 0) { %>
    <p class="muted small">대상 서버가 없습니다 (servers.csv 확인)</p>
  <% } %>
</div>

<!-- 호스트 목록 -->
<div class="section-box">
  <h3>호스트 목록</h3>
  <div class="table-scroll" style="overflow-x:auto;">
  <table class="data-table">
    <thead>
      <tr>
        <th>호스트명</th><th>OS</th><th>IP</th>
        <th>취약점 개수</th><th>준수율 (양호/전체)</th>
        <th>운영자</th><th>도메인</th><th>통신방식</th><th>점검상태</th>
      </tr>
    </thead>
    <tbody>
      <% agents.forEach(a => { %>
        <tr>
          <td><strong><%= a.hostname %></strong></td>
          <td><span class="os-badge os-<%= a.os_type %>"><%= String(a.os_type||'').toUpperCase() %></span></td>
          <td class="mono small"><%= a.ip_address %></td>
          <td><%= a.checked ? a.vuln_count : '-' %></td>
          <td>
            <% if (a.checked && a.score_total) { %>
              <strong><%= a.score %> / <%= a.score_total %></strong> <span class="muted small">(<%= a.grade_pct %>%)</span>
            <% } else { %><span class="muted">-</span><% } %>
          </td>
          <td class="small"><%= a.operator %></td>
          <td class="small"><%= a.domain %></td>
          <td><span class="ch-badge"><%= a.channel %></span></td>
          <td>
            <% if (a.checked) { %><span class="chk-yes">완료</span>
            <% } else { %><span class="chk-no">미점검</span><% } %>
          </td>
        </tr>
      <% }); %>
      <% if (!agents.length) { %><tr><td colspan="9" class="empty">대상 서버가 없습니다</td></tr><% } %>
    </tbody>
  </table>
  </div>
</div>

<%- include('../_footer') %>
