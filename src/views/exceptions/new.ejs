<%- include('../_header', { title: '예외 신청', activeMenu: 'exceptions' }) %>

<div class="page-header">
  <h1>예외 신청 (일괄 설정)</h1>
  <p class="muted small">
    취약 판정 항목에 대한 한시적 예외 처리. CISO 승인 후 효력 발생.
    점검항목 × 대상(호스트/계정)을 한 번에 등록할 수 있습니다.
  </p>
  <div class="header-actions"><a href="/exceptions" class="btn">← 예외 관리</a></div>
</div>

<form id="exceptionForm" class="form-container">
<% var isPost = !!(prefill && prefill.result_id); %>
<% if (isPost) { %>
  <!-- 사후 예외: 항목·서버 고정. 호스트 단위=체크박스 / 그 외 단위(계정 등)=자유 입력 -->
  <div class="form-section">
    <h3>사후 예외 대상</h3>
    <input type="hidden" name="result_id" value="<%= prefill.result_id %>">
    <input type="hidden" name="scope_type" value="result">
    <input type="hidden" name="hostname" value="<%= prefill.hostname || '' %>">
    <input type="hidden" name="title" value="사후 예외 <%= prefill.rule_id || '' %> @ <%= prefill.hostname || '' %>">
    <input type="hidden" name="policy" value="전자금융기반시설_2026_OS">
    <input type="hidden" name="related_basis" value="진단결과 <%= prefill.result_id %> 사후 예외">
    <input type="hidden" id="postRuleId" value="<%= prefill.rule_id || '' %>">
    <input type="hidden" id="postItemTitle" value="<%= prefill.title || '' %>">
    <p class="muted small">점검항목 <code><%= prefill.rule_id || '-' %></code> <%= prefill.title ? ('· ' + prefill.title) : '' %> · 서버 <b><%= prefill.hostname || '-' %></b></p>

    <!-- 호스트 단위: 체크박스 (편하게) -->
    <label style="display:block;margin:8px 0;"><input type="checkbox" id="serverScope" checked> <b>이 서버(호스트) 전체</b>에 예외 적용 <span class="muted">(호스트 단위)</span></label>

    <!-- 계정 단위: ① 체크박스 ② 다중 입력 ③ CSV -->
    <div id="acctArea" style="border-left:3px solid #e1e5ea;padding-left:12px;margin-top:6px;">
      <p id="scopeHint" class="muted small" style="margin:0 0 8px;"></p>
      <% if (accounts && accounts.length) { %>
        <div class="form-row inline" style="align-items:center;">
          <label>계정 선택 <span class="muted small">(체크)</span></label>
          <button type="button" class="btn-sm" onclick="acctAll(true)">로그인계정 전체</button>
          <button type="button" class="btn-sm" onclick="acctAll(false)">해제</button>
          <label style="font-weight:400;margin-left:8px;"><input type="checkbox" id="showAllAcct"> 시스템(nologin) 계정도 표시</label>
        </div>
        <div id="acctList" style="max-height:160px;overflow:auto;border:1px solid #e1e5ea;border-radius:6px;padding:8px;margin-bottom:8px;">
          <% accounts.forEach(a => { %>
            <label class="acct-opt" data-login="<%= a.login ? 1 : 0 %>"
                   style="display:inline-block;width:auto;margin:2px 10px 2px 0;font-weight:400;<%= a.login ? '' : 'display:none;' %>">
              <input type="checkbox" class="acctChk" value="<%= a.name %>"> <code><%= a.name %></code><% if (!a.login) { %> <span class="muted small">(nologin)</span><% } %>
            </label>
          <% }) %>
        </div>
      <% } else { %>
        <p class="muted small">이 서버의 계정 목록을 찾지 못했습니다 (스크립트 진단 원본 없음). 아래에 직접 입력/붙여넣기 하세요.</p>
      <% } %>
      <div class="form-row inline">
        <label>계정 직접 입력 <span class="muted small">(쉼표/공백 다중)</span></label>
        <input type="text" id="postUserText" placeholder="예: root, jessy72, test*">
      </div>
      <div class="form-row">
        <label>CSV 붙여넣기 <span class="muted small">(한 줄 1계정, 또는 호스트,계정)</span></label>
        <textarea id="postCsv" rows="3" placeholder="root&#10;jessy72&#10;test*"></textarea>
      </div>
    </div>
  </div>
<% } else { %>

  <!-- ① 기본 정보 -->
  <div class="form-section">
    <h3>① 기본 정보</h3>
    <div class="form-row inline">
      <label>제목 *</label>
      <input type="text" name="title" required
             placeholder="예: 전자금융기반시설 2026 OS 예외 일괄 (2026-1분기)"
             value="<%= (prefill && prefill.title) || '' %>">
    </div>
    <div class="form-row inline">
      <label>정책</label>
      <select name="policy">
        <option value="전자금융기반시설_2026_OS">전자금융기반시설_2026_OS</option>
      </select>
    </div>
    <div class="form-row inline">
      <label>OS</label>
      <span style="display:inline-flex;gap:14px;flex-wrap:wrap;">
        <% ['HPUX','AIX','Solaris','Linux','Windows'].forEach((o,i) => { %>
          <label style="font-weight:400;"><input type="radio" name="os" value="<%= o %>" data-os <%= i===3?'checked':'' %>> <%= o %></label>
        <% }) %>
      </span>
    </div>
    <div class="form-row">
      <label>관련 근거 *</label>
      <textarea name="related_basis" required rows="2"
                placeholder="예외의 근거 (진단결과 ID, 승인 티켓번호, 관련 규정·공문, 검토 회의록 등) — 감사 추적·사후 필터용"><%= (prefill && prefill.related_basis) || '' %></textarea>
    </div>
  </div>

  <!-- ② 점검 항목 선택 (검색 + 다중) -->
  <div class="form-section">
    <h3>② 점검 항목 선택 <span class="muted small">(검색·다중 선택)</span></h3>
    <div class="form-row inline">
      <label>항목 검색</label>
      <input type="text" id="itemSearch" placeholder="SRV 코드 또는 제목으로 검색...">
      <button type="button" class="btn-sm" onclick="toggleAllItems(true)">전체선택</button>
      <button type="button" class="btn-sm" onclick="toggleAllItems(false)">해제</button>
      <span class="muted small" id="itemCount"></span>
    </div>
    <div id="itemList" style="max-height:220px;overflow:auto;border:1px solid #e1e5ea;border-radius:6px;padding:8px;">
      <% (checkItems || []).forEach(ci => { %>
        <label class="item-opt" data-text="<%= (ci.srv + ' ' + ci.title).toLowerCase() %>"
               style="display:block;font-weight:400;padding:2px 4px;">
          <input type="checkbox" name="rule_ids" value="<%= ci.srv %>"
                 <%= prefill && prefill.rule_id === ci.srv ? 'checked' : '' %>>
          <code><%= ci.srv %></code> · <%= ci.title %>
        </label>
      <% }) %>
    </div>
  </div>

  <!-- ③ 대상 (호스트 + 계정) : 단일 / 패턴 / CSV import -->
  <div class="form-section">
    <h3>③ 대상 (호스트 · 계정)</h3>
    <% if (prefill && prefill.result_id) { %>
      <input type="hidden" name="result_id" value="<%= prefill.result_id %>">
      <input type="hidden" name="scope_type" value="result">
      <p class="muted small">🔗 진단 결과 <code><%= prefill.result_id %></code> 사후 예외</p>
    <% } %>
    <div class="form-row inline">
      <label>호스트명</label>
      <input type="text" name="hostname" list="hostList" placeholder="검색·선택 (호스트명/IP). CSV 일괄 시 비움"
             value="<%= (prefill && prefill.hostname) || '' %>">
      <datalist id="hostList">
        <% (servers || []).forEach(s => { %>
          <option value="<%= s.hostname %>"><%= s.hostname %> — <%= s.ip || s.ip_address || '' %> (<%= s.os || s.os_type || '' %>)</option>
        <% }) %>
      </datalist>
    </div>
    <div class="form-row inline">
      <label>계정명 / 패턴</label>
      <input type="text" name="username" placeholder="계정 단위만 (예: jessy72). 와일드카드 * 가능(예: test*). 호스트 전체면 비움"
             value="<%= (prefill && prefill.username) || '' %>">
    </div>
    <div class="form-row">
      <label>CSV / Excel 일괄</label>
      <textarea name="targets_csv" rows="4" placeholder="호스트명,계정명  (한 줄에 하나)&#10;jessy207,jessy72&#10;jessy207,test*&#10;jessy167,   ← 계정 비우면 호스트 전체"></textarea>
      <span class="muted small">여러 호스트/계정에 선택 점검항목 예외를 한 번에. <a href="/exceptions/template.csv">CSV 템플릿</a> · (CSV 입력 시 위 단일 호스트/계정 무시)</span>
    </div>
  </div>

<% } %>

  <!-- 사유 -->
  <div class="form-section">
    <h3>예외 사유</h3>
    <div class="form-row inline">
      <label>유형 *</label>
      <select name="reason_type" required>
        <option value="">— 선택 —</option>
        <option value="비즈니스 요구">비즈니스 요구 (서비스 영향)</option>
        <option value="레거시 호환">레거시 시스템 호환성</option>
        <option value="대체 통제">대체 통제 (Compensating Control)</option>
        <option value="패치 불가">벤더 패치 미제공</option>
        <option value="검토 중">조치 방안 검토 중</option>
        <option value="기타">기타</option>
      </select>
    </div>
    <div class="form-row">
      <label>상세 사유 *</label>
      <textarea name="reason" required rows="4" placeholder="예외 처리가 필요한 구체적 사유"></textarea>
    </div>
    <div class="form-row">
      <label>대체 통제</label>
      <textarea name="compensating_control" rows="2" placeholder="위험 완화 통제 (방화벽 차단, 모니터링 강화 등)"></textarea>
    </div>
  </div>

  <!-- 유효기간 -->
  <div class="form-section">
    <h3>유효기간</h3>
    <div class="form-row inline">
      <label>시작일 *</label>
      <input type="date" name="effective_from" id="effFrom" required value="<%= new Date().toISOString().slice(0,10) %>">
    </div>
    <div class="form-row inline">
      <label>종료일</label>
      <input type="date" name="effective_until" id="effUntil">
      <label style="font-weight:400;margin-left:10px;"><input type="checkbox" name="indefinite" id="indefinite" value="1"> 무기한</label>
    </div>
    <p class="muted small">권장 30~90일. 무기한은 종료일 없이 영구 적용.</p>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn primary">예외 신청</button>
    <a href="/exceptions" class="btn">취소</a>
  </div>
</form>

<script>
// 항목 검색 필터 (일괄 모드에만 존재 — 사후 예외 간소폼에선 #itemList 없음)
var itemSearch = document.getElementById('itemSearch');
var itemListEl = document.getElementById('itemList');
function refreshItemCount(){
  if (!itemListEl) return;
  var n = document.querySelectorAll('#itemList input[name="rule_ids"]:checked').length;
  var cnt = document.getElementById('itemCount'); if (cnt) cnt.textContent = '선택 ' + n + '개';
}
if (itemSearch && itemListEl) {
  itemSearch.addEventListener('input', function(){
    var q = itemSearch.value.toLowerCase().trim();
    document.querySelectorAll('#itemList .item-opt').forEach(function(el){
      el.style.display = (!q || el.dataset.text.indexOf(q) >= 0) ? 'block' : 'none';
    });
  });
  itemListEl.addEventListener('change', refreshItemCount);
  refreshItemCount();
}
function toggleAllItems(on){
  if (!itemListEl) return;
  document.querySelectorAll('#itemList .item-opt').forEach(function(el){
    if (el.style.display === 'none') return;
    el.querySelector('input').checked = on;
  });
  refreshItemCount();
}

// 사후 예외 — 계정 대상: 체크박스 + 다중입력 + CSV (전역 함수)
function collectPostAccounts(){
  var set = {};
  document.querySelectorAll('.acctChk:checked').forEach(function(c){ var v=c.value.trim(); if(v) set[v]=1; });
  var tx = document.getElementById('postUserText');
  if (tx) tx.value.split(/[\s,]+/).forEach(function(v){ v=v.trim(); if(v) set[v]=1; });
  var csv = document.getElementById('postCsv');
  if (csv) csv.value.split(/\r?\n/).forEach(function(line){
    var p = line.split(','); var acct = (p.length>1 ? p[p.length-1] : p[0]).trim();
    if (acct) set[acct]=1;
  });
  return Object.keys(set);
}
function paintScope(){
  var ss = document.getElementById('serverScope');
  var area = document.getElementById('acctArea');
  var hint = document.getElementById('scopeHint');
  if (!ss) return;
  if (ss.checked) {
    if (area) area.style.opacity = '0.45';
    if (hint) hint.textContent = '→ 이 호스트의 모든 대상에 예외 적용 (호스트 단위). 계정 지정하려면 위 체크 해제';
  } else {
    if (area) area.style.opacity = '1';
    var acc = collectPostAccounts();
    if (hint) hint.textContent = acc.length
      ? '→ 계정 ' + acc.length + '개에만 예외: ' + acc.slice(0,8).join(', ') + (acc.length>8?' …':'')
      : '→ 계정을 체크/입력/붙여넣기 하세요 (비우면 호스트 단위와 동일)';
  }
}
function acctAll(on){
  document.querySelectorAll('#acctList .acct-opt').forEach(function(el){
    if (el.style.display === 'none') return;
    var c = el.querySelector('input'); if (c) c.checked = on;
  });
  var ss = document.getElementById('serverScope'); if (ss) ss.checked = false;
  paintScope();
}
(function(){
  var ss = document.getElementById('serverScope');
  var ti = document.getElementById('postItemTitle');
  if (!ss) return;  // 사후 모드에서만
  var ACCOUNT_KW = ['패스워드','비밀번호','암호','계정','사용자','유저','로그온','로그인','세션','잠금','만료','변경주기','권한','소유자','홈디렉','쉘','shell','password','passwd','account','user','login','uid','lockout','expire'];
  var title = (ti && ti.value || '').toLowerCase();
  if (ACCOUNT_KW.some(function(k){ return title.indexOf(k.toLowerCase()) >= 0; })) ss.checked = false;
  ss.addEventListener('change', paintScope);
  var tx = document.getElementById('postUserText'); if (tx) tx.addEventListener('input', function(){ ss.checked=false; paintScope(); });
  var csv = document.getElementById('postCsv'); if (csv) csv.addEventListener('input', function(){ ss.checked=false; paintScope(); });
  document.querySelectorAll('.acctChk').forEach(function(c){ c.addEventListener('change', function(){ ss.checked=false; paintScope(); }); });
  var showAll = document.getElementById('showAllAcct');
  if (showAll) showAll.addEventListener('change', function(){
    document.querySelectorAll('#acctList .acct-opt').forEach(function(el){
      if (el.dataset.login === '0') el.style.display = showAll.checked ? 'inline-block' : 'none';
    });
  });
  paintScope();
})();

// 무기한 토글
var indef = document.getElementById('indefinite'), effUntil = document.getElementById('effUntil');
indef.addEventListener('change', function(){ effUntil.disabled = indef.checked; if(indef.checked) effUntil.value=''; });

// 기본 종료일 = 시작일 +30일
(function(){ var f=document.getElementById('effFrom'), u=document.getElementById('effUntil');
  function set(){ if(indef.checked) return; var d=new Date(f.value); d.setDate(d.getDate()+30); u.value=d.toISOString().slice(0,10); }
  set(); f.addEventListener('change', set);
})();

document.getElementById('exceptionForm').onsubmit = async function(e){
  e.preventDefault();
  var data = Object.fromEntries(new FormData(e.target));
  // 점검항목 — 일괄 모드는 다중선택, 사후 모드는 고정 항목(postRuleId)
  var postRule = document.getElementById('postRuleId');
  if (postRule) {
    data.rule_ids = [postRule.value];
    var ss = document.getElementById('serverScope');
    if (ss && ss.checked) {
      data.username = '';                       // 호스트 단위
    } else {
      var accts = collectPostAccounts();          // 체크박스 + 다중입력 + CSV 통합
      if (!accts.length) { alert('계정을 1개 이상 선택/입력/붙여넣기 하거나, "이 서버 전체" 체크박스를 선택하세요.'); return; }
      data.targets = accts.map(function(u){ return { hostname: data.hostname || '', username: u }; });
      delete data.username;
    }
  } else {
    data.rule_ids = Array.from(document.querySelectorAll('#itemList input[name="rule_ids"]:checked')).map(function(c){return c.value;});
  }
  if (!data.rule_ids.length || !data.rule_ids[0]) { alert('점검 항목을 1개 이상 선택하세요.'); return; }
  // 기간 검증
  if (!data.indefinite && (!data.effective_until || data.effective_until <= data.effective_from)) {
    alert('종료일은 시작일 이후여야 합니다. (또는 무기한 체크)'); return;
  }
  // CSV 일괄
  if (data.targets_csv && data.targets_csv.trim()) {
    data.targets = data.targets_csv.trim().split(/\r?\n/).map(function(line){
      var p = line.split(','); return { hostname:(p[0]||'').trim(), username:(p[1]||'').trim() };
    }).filter(function(t){ return t.hostname || t.username; });
    if (!data.targets.length) { alert('CSV 형식 확인 (호스트명,계정명).'); return; }
  }
  delete data.targets_csv;

  var res = await fetch('/exceptions/save', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
  var j = await res.json();
  if (j.status === 'success') {
    alert('예외 신청 등록 (승인 대기). ' + (j.count>1 ? j.count+'건 생성.' : ''));
    location.href = '/exceptions';
  } else { alert('실패: ' + (j.error || '오류')); }
};
</script>

<%- include('../_footer') %>
