<%- include('../_header', { title: '정합성 검증 #' + assessment_id, activeMenu: 'diagnosis' }) %>

<div class="page-header">
  <h1>정합성 검증 — 진단 #<%= assessment_id %></h1>
  <p class="muted small">
    KISA 30개 룰 진단 결과와 SecuMS 원본 진단 결과의 정합성을 비교합니다.
    SecuMS는 64개 자체 항목을 점검하므로 직접 비교 가능한 것은 매핑된 일부 항목입니다.
  </p>
  <div class="header-actions">
    <a href="/diagnosis" class="btn">← 진단 관리</a>
    <a href="/reports/<%= assessment_id %>/fsi" class="btn">리포트1</a>
  </div>
</div>

<!-- 점검 범위 비교 -->
<div class="section-box" style="background:#fff8e1;border-left:4px solid #f9a825;">
  <h3>⚠ 점검 범위 차이</h3>
  <p>
    <strong>SecuMS</strong>는 64개 자체 항목(<code>os-linux-XXX</code>)을 점검하고,
    <strong>본 시스템</strong>은 KISA 가이드의 30개 핵심 항목(<code>U-01 ~ U-30</code>)을 점검합니다.
    같은 영역을 다른 분류로 점검하므로 항목 수가 단순 비교되지 않습니다.
  </p>
  <ul style="margin-top:0.5rem;">
    <li><strong>SecuMS 결과</strong>:
      OK <strong style="color:#27ae60;"><%= validation.secumsStats.OK %></strong>,
      BAD <strong style="color:#c0392b;"><%= validation.secumsStats.BAD %></strong>,
      INFO <strong><%= validation.secumsStats.INFO %></strong>,
      WAIT(점검 안 함) <strong style="color:#888;"><%= validation.secumsStats.WAIT %></strong>
      / 전체 <%= validation.secumsStats.total %>개
    </li>
    <li><strong>본 시스템 결과</strong>:
      취약 <strong style="color:#c0392b;"><%= validation.ourStats.vuln %></strong>,
      양호 <strong style="color:#27ae60;"><%= validation.ourStats.safe %></strong>,
      점검불가 <strong style="color:#888;"><%= validation.ourStats.na %></strong>
      / 전체 <%= validation.ourStats.total %>개
    </li>
  </ul>
</div>

<!-- 평가 방식 신뢰도 -->
<div class="section-box" style="background:#e3f2fd;border-left:4px solid #1976d2;">
  <h3>본 시스템 평가 방식 (mock 모드 신뢰도)</h3>
  <table class="data-table" style="max-width:700px;">
    <thead>
      <tr><th>평가 방식</th><th>건수</th><th>취약 판정</th><th>신뢰도</th></tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>simple_check</strong> (deterministic)</td>
        <td><%= validation.ourStats.bySimple %>건</td>
        <td><%= validation.ourStats.vulnBySimple %>건</td>
        <td><span style="color:#27ae60;">✓ 실제 raw 데이터 평가</span></td>
      </tr>
      <tr style="background:#fff5f5;">
        <td><strong>LLM 평가</strong> (mock 모드)</td>
        <td><%= validation.ourStats.byLlm %>건</td>
        <td><%= validation.ourStats.vulnByLlm %>건</td>
        <td>
          <span style="color:#c0392b;">⚠ mock LLM 임의 판정 — 실서비스에서 Ollama/실 LLM 연결 필요</span>
        </td>
      </tr>
    </tbody>
  </table>
  <p class="muted small" style="margin-top:0.5rem;">
    LLM 평가 룰은 mock 모드에서 실제 데이터를 분석하지 않습니다.
    실서비스 모드에서 <code>LLM_PROVIDER=ollama</code> 등으로 전환 시 정확한 판정이 가능합니다.
  </p>
</div>

<!-- 매핑 비교 KPI -->
<div class="kpi-grid kpi-4col">
  <div class="kpi-card">
    <div class="kpi-label">매핑된 룰</div>
    <div class="kpi-num"><%= validation.mapped %></div>
    <div class="kpi-sub">비교 가능 항목 / KISA 30 중</div>
  </div>
  <div class="kpi-card kpi-success">
    <div class="kpi-label">일치</div>
    <div class="kpi-num" style="color:#27ae60;"><%= validation.matched %></div>
    <div class="kpi-sub">SecuMS와 동일 판정</div>
  </div>
  <div class="kpi-card kpi-fail">
    <div class="kpi-label">불일치</div>
    <div class="kpi-num" style="color:#c0392b;"><%= validation.mismatched %></div>
    <div class="kpi-sub">재확인 필요</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">일치율</div>
    <div class="kpi-num"
         style="color:<%= validation.matchRate >= 80 ? '#27ae60' : validation.matchRate >= 60 ? '#e67e22' : '#c0392b' %>;">
      <%= validation.matchRate %>%
    </div>
    <div class="kpi-sub">매핑 기준</div>
  </div>
</div>

<!-- 검증된 매핑만의 일치율 (raw DB로 매핑 확인된 8건) -->
<div class="section-box">
  <h3>검증된 매핑 (raw DB의 SecuMS BAD 메시지로 매핑 확인된 항목)</h3>
  <p class="muted small">
    SecuMS BAD 결과의 ITEM/MSG 분석을 통해 KISA U-XX와 동일 영역을 점검하는 것으로 확인된 항목.
    추정 매핑(매핑 표에 ? 표시)의 일치율은 점검 영역 일치 여부에 따라 달라질 수 있습니다.
  </p>
  <div style="display:flex;gap:1.5rem;margin-top:0.5rem;">
    <div>
      <strong>검증된 매핑 일치율:</strong>
      <span style="color:<%= validation.verifiedMatchRate >= 80 ? '#27ae60' : validation.verifiedMatchRate >= 60 ? '#e67e22' : '#c0392b' %>;font-weight:600;font-size:1.2rem;">
        <%= validation.verifiedMatchRate %>%
      </span>
      <span class="muted">(일치 <%= validation.verifiedMatched %> / 불일치 <%= validation.verifiedMismatched %>)</span>
    </div>
  </div>
</div>

<!-- 매핑된 룰별 상세 비교 -->
<div class="section-box">
  <h3>룰별 정합성 비교 (KISA U-XX ↔ SecuMS CHK_ID)</h3>
  <table class="data-table">
    <thead>
      <tr>
        <th>KISA</th>
        <th>SecuMS CHK_ID</th>
        <th>제목</th>
        <th>본 시스템</th>
        <th>SecuMS</th>
        <th>정합성</th>
        <th>평가방식</th>
        <th>매핑상태</th>
      </tr>
    </thead>
    <tbody>
      <% validation.mappedRules.forEach(r => { %>
        <% var rowBg = !r.comparable ? '#f5f5f5'
                     : r.match ? 'transparent'
                     : '#fff5f5'; %>
        <tr style="background:<%= rowBg %>;">
          <td class="mono"><strong><%= r.ruleId %></strong></td>
          <td class="mono small"><%= r.secumsIds.join(', ') %></td>
          <td style="max-width:300px;"><%= r.title %></td>
          <td>
            <% if (r.ourSt === 'BAD') { %>
              <span style="color:#c0392b;font-weight:600;">🚨 취약</span>
            <% } else if (r.ourSt === 'OK') { %>
              <span style="color:#27ae60;">✓ 양호</span>
            <% } else { %>
              <span class="muted">? <%= r.ourSt %></span>
            <% } %>
          </td>
          <td>
            <% if (r.secumsSt === 'BAD') { %>
              <span style="color:#c0392b;font-weight:600;">🚨 BAD</span>
            <% } else if (r.secumsSt === 'OK') { %>
              <span style="color:#27ae60;">✓ OK</span>
            <% } else if (r.secumsSt === 'WAIT') { %>
              <span class="muted">- WAIT (점검 안 함)</span>
            <% } else { %>
              <span class="muted">? <%= r.secumsSt %></span>
            <% } %>
          </td>
          <td>
            <% if (!r.comparable) { %>
              <span class="muted">비교 불가</span>
            <% } else if (r.match) { %>
              <span style="color:#27ae60;font-weight:600;">✓ 일치</span>
            <% } else { %>
              <span style="color:#c0392b;font-weight:600;">✗ 불일치</span>
            <% } %>
          </td>
          <td>
            <% if (r.eval_method === 'simple') { %>
              <span style="color:#27ae60;" title="실제 raw 데이터 평가">simple</span>
            <% } else if (r.eval_method === 'llm') { %>
              <span style="color:#c0392b;" title="mock LLM 임의 판정">⚠ mock-llm</span>
            <% } else { %>
              <span class="muted"><%= r.eval_method %></span>
            <% } %>
          </td>
          <td>
            <% if (r.verified) { %>
              <span style="color:#27ae60;" title="raw DB MSG로 매핑 확인">✓ 검증</span>
            <% } else { %>
              <span class="muted" title="점검 영역 추정 매핑">? 추정</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- SecuMS의 점검 안 한 항목 (WAIT) -->
<% var waitItems = validation.secumsNotCovered.filter(s => s.result === 'WAIT'); %>
<% if (waitItems.length) { %>
  <div class="section-box">
    <h3>SecuMS 점검 미수행 항목 (WAIT — <%= waitItems.length %>건)</h3>
    <p class="muted small">
      SecuMS 정책에는 포함됐지만 실제 수집이 안 된 항목. raw DB에 결과 데이터가 없어 비교 불가.
    </p>
    <div class="mono small" style="background:#f5f5f5;padding:0.5rem;border-radius:4px;">
      <%= waitItems.map(s => s.chkId).join(', ') %>
    </div>
  </div>
<% } %>

<!-- SecuMS의 KISA 30 범위 밖 BAD 항목 -->
<% var unmappedBad = validation.secumsNotCovered.filter(s => s.result === 'BAD'); %>
<% if (unmappedBad.length) { %>
  <div class="section-box" style="background:#fff5f5;border-left:4px solid #c0392b;">
    <h3>SecuMS BAD 중 KISA 30 룰 미매핑 (<%= unmappedBad.length %>건)</h3>
    <p class="muted small">
      SecuMS는 취약으로 판정했지만 KISA 30 범위에 매핑되지 않은 항목.
      운영 정책에서 다룰 필요가 있다면 룰셋 확장 검토 필요.
    </p>
    <table class="data-table">
      <thead>
        <tr><th>SecuMS CHK_ID</th><th>결과</th></tr>
      </thead>
      <tbody>
        <% unmappedBad.forEach(s => { %>
          <tr>
            <td class="mono"><%= s.chkId %></td>
            <td><span style="color:#c0392b;font-weight:600;">🚨 <%= s.result %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../_footer') %>
